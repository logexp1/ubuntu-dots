#!/bin/bash
# Fuzzy tab switcher for kitty (≈ tmux prefix+s session list)
# Requires: allow_remote_control yes in kitty.conf

result=$(kitty @ ls 2>/dev/null | python3 -c "
import sys, json
data = json.load(sys.stdin)
for os_win in data:
    for tab in os_win.get('tabs', []):
        marker = '>' if tab.get('is_focused') else ' '
        print(f\"{tab['id']}\t{marker} {tab['title']}\")
" | fzf --with-nth=2.. \
       --delimiter='\t' \
       --bind='j:down,k:up' \
       --prompt='tab> ' \
       --height=40%)

[ -z "$result" ] && exit 0

tab_id=$(echo "$result" | cut -f1)
kitty @ focus-tab --match "id:$tab_id"
