#!/usr/bin/env bash

export GRIMBLAST_EDITOR="satty --filename"

screenshot_opts=("󰍺 All Screen" "󰍹 Active Screen" "󱣴 Capture Area")
action_opts=(" Copy" " Save" " Copy & Save" " Edit")

rofi_menu() {
    local prompt="$1"; shift
    printf '%s\n' "$@" | rofi -dmenu -p "$prompt"
}

type_choice=$(rofi_menu "Screenshot" "${screenshot_opts[@]}") || exit 1
case "$type_choice" in
    "󰍺 All Screen")    option_type="screen" ;;
    "󰍹 Active Screen") option_type="active" ;;
    "󱣴 Capture Area")  option_type="area" ;;
    *) exit 1 ;;
esac

action_choice=$(rofi_menu "Action" "${action_opts[@]}") || exit 1
case "$action_choice" in
    " Copy")        option_action="copy" ;;
    " Save")        option_action="save" ;;
    " Copy & Save") option_action="copysave" ;;
    " Edit")        option_action="edit" ;;
    *) exit 1 ;;
esac

mkdir -p "${XDG_SCREENSHOTS_DIR:-$HOME/Pictures/Screenshots}"
DEFAULT_TARGET_DIR="${XDG_SCREENSHOTS_DIR:-$HOME/Pictures/Screenshots}" \
    grimblast -n "$option_action" "$option_type"
